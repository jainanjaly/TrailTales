FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=trailtales

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

FRONTEND_ORIGIN=http://localhost:5173

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

COLLAB_INVITE_SECRET=change-me-too

# SendGrid SMTP (Phase 7 — collaborator invite emails)
# Sign up at sendgrid.com (free tier: 100 emails/day), create an API key
# with "Mail Send" permission, and verify a sender identity (Single Sender
# Verification works for dev; domain auth is needed for production).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SMTP_SECURITY=starttls
SMTP_FROM=
SMTP_FROM_NAME=TrailTales
